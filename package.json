{
  "name": "tokpack",
  "version": "0.1.0",
  "description": "Pack more data into fewer tokens — JSON compression library for LLM context optimization",
  "type": "module",
  "main": "./dist/lib.cjs",
  "module": "./dist/lib.mjs",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.mjs",
      "require": "./dist/lib.cjs"
    }
  },
  "bin": {
    "tokpack": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/lib.mjs",
    "dist/lib.cjs",
    "dist/lib.d.ts",
    "dist/lib.d.ts.map"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "bench": "npx tsx scripts/bench.ts",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "token-optimization",
    "llm",
    "ai",
    "json-compression",
    "mcp",
    "claude",
    "anthropic",
    "context-window",
    "psv",
    "token-packing"
  ],
  "author": "tokpack contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/mykhlv/tokpack"
  },
  "bugs": {
    "url": "https://github.com/mykhlv/tokpack/issues"
  },
  "homepage": "https://github.com/mykhlv/tokpack#readme",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
